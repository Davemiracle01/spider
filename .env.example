# ─────────────────────────────────────────────
# Gabimaru Bot — Environment Variables
# Copy this to .env for local dev
# On Heroku: set these via heroku config:set
# ─────────────────────────────────────────────

# REQUIRED — Heroku app URL (for keepalive self-ping)
APP_URL=https://YOUR-APP-NAME.herokuapp.com

# OPTIONAL — Groq AI API key (for chatbot feature)
# Get free key at https://console.groq.com
GROQ_API_KEY=

# OPTIONAL — Telegram bot token (for .telesticker command)
TELEGRAM_BOT_TOKEN=

# OPTIONAL — Session secret for web dashboard
SESSION_SECRET=your_random_secret_here_change_this

# OPTIONAL — Timezone (default: Africa/Nairobi)
TZ=Africa/Nairobi

# DO NOT CHANGE — Heroku sets this automatically
PORT=3000
NODE_ENV=production
