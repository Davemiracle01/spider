# ─── Spider-Venom Bot v6 Environment Variables ───────────────────────────────

# REQUIRED: Set this to a strong password — only you know it!
ADMIN_PASSWORD=your_strong_password_here

# Optional: Change session secret for extra security
SESSION_SECRET=your_session_secret_here

# AI Chatbot (Groq API Key)
GROQ_API_KEY=your_groq_api_key_here

# Timezone
TZ=Africa/Nairobi

# Node environment
NODE_ENV=production
